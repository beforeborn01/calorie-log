# ============================================
# 食养记 docker-compose 环境变量模板
# 复制为 .env 后按需修改；生产环境请务必替换 JWT_SECRET / DB 密码
# ============================================

# --- 部署模式 ---
SPRING_PROFILES_ACTIVE=dev

# --- 端口映射到宿主机 ---
APP_PORT=8080
# 宿主机 5432 / 6379 常被本地 postgres / redis 占用，默认各 +1 避开
POSTGRES_PORT=5433
REDIS_PORT=6380

# --- PostgreSQL ---
POSTGRES_DB=calorie_log_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# --- Redis ---
REDIS_PASSWORD=

# --- 安全：JWT 签名密钥（务必替换为 64+ 字符强随机字符串） ---
JWT_SECRET=dev-only-insecure-secret-please-override-in-production-environment-00000000

# --- 微信开放平台（未配置时 dev 模式会 mock） ---
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# --- 火山引擎 VeSMS 短信（Phase 3 接入） ---
VOLC_ACCESS_KEY_ID=
VOLC_ACCESS_KEY_SECRET=
VOLC_SMS_SIGN_NAME=
VOLC_SMS_TEMPLATE_ID=

# --- 百度 AI（Phase 5 拍照识别） ---
BAIDU_AI_API_KEY=
BAIDU_AI_SECRET_KEY=
