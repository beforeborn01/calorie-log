# 食养记 - 生产环境变量样板
# 使用：cp .env.prod.example .env 并修改下方所有 REPLACE_ME

# ----- 必填：数据库 -----
POSTGRES_DB=calorie_log_db
POSTGRES_USER=calorie_log
# 至少 16 位，建议 `openssl rand -base64 24`
POSTGRES_PASSWORD=REPLACE_ME_STRONG_POSTGRES_PWD

# ----- 必填：Redis 密码（建议设，避免被扫） -----
# 留空则 redis-server 不启用密码（仅 docker 内网可达，低风险但仍建议设）
REDIS_PASSWORD=REPLACE_ME_REDIS_PWD

# ----- 必填：JWT 密钥（HS512 要求 >= 64 字节） -----
# 生成命令：openssl rand -base64 64 | tr -d '\n'
JWT_SECRET=REPLACE_ME_JWT_SECRET_AT_LEAST_64_CHARS_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ----- 可选：微信开放平台（未配则走 dev mock 流程） -----
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# ----- 可选：火山引擎短信（未配则验证码打在日志） -----
VOLC_ACCESS_KEY_ID=
VOLC_ACCESS_KEY_SECRET=
VOLC_SMS_SIGN_NAME=
VOLC_SMS_TEMPLATE_ID=

# ----- 可选：百度 AI 图像识别（未配则走 Mock 识别） -----
BAIDU_AI_API_KEY=
BAIDU_AI_SECRET_KEY=
